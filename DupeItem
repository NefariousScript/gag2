-- MINIMIZE / RESTORE (smooth slide & pop bounce)
----------------------------------------------------
local minimized = false
local fullHeight = 260
local miniHeight = 42

local function minimize()
    minimized = true
    -- Clean glide-up using smooth Quart easing
    local minimizeTween = TweenService:Create(main, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 340, 0, miniHeight)
    })
    minimizeTween:Play()
    
    -- Disables content visibility safely once the shrink finishes
    task.spawn(function()
        minimizeTween.Completed:Wait()
        if minimized then
            content.Visible = false
        end
    end)
end

local function restore()
    minimized = false
    content.Visible = true
    -- Modern slide down with a subtle pop/bounce on settle
    TweenService:Create(main, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 340, 0, fullHeight)
    }):Play()
end

minimizeBtn.MouseButton1Click:Connect(function()
    if not minimized then minimize() else restore() end
end)

